{
    "name": "brewery/management-system",
    "description": "Hofer BrauHaus Brewery Management System",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,

    "require": {
        "php": ">=8.0.0",
        "yiisoft/yii2": "~2.0.45",
        "yiisoft/yii2-bootstrap5": "~2.0.0",
        "yiisoft/yii2-symfonymailer": "~2.0.0"
    },

    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },

    "config": {
        "process-timeout": 1800,
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        },
        "platform-check": false
    },

    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],

    "autoload": {
        "psr-4": {
            "common\\": "common/",
            "frontend\\": "frontend/",
            "backend\\": "backend/",
            "console\\": "console/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests/"
        }
    },

    "extra": {
        "asset-installer-paths": {
            "npm-asset-library": "vendor/npm-asset",
            "bower-asset-library": "vendor/bower-asset"
        }
    }
}
